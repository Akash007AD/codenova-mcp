# ================================================
# CodeNova MCP Server - Environment Variables
# ================================================
# Copy: copy .env.example .env   (Windows)
#       cp .env.example .env     (Linux/Mac)
# ================================================

# ── Server Access Secret (REQUIRED) ────────────
# Every tool call must pass this as the `server_secret` argument.
# Generate one: python -c "import secrets; print(secrets.token_hex(24))"
# Share this with users who should be allowed to use this server.
SERVER_SECRET=your_secret_here

# ── GitHub Personal Access Token (per-call, not server env) ──────
# In multi-user mode, each user passes their OWN token as `github_token`
# in every tool call. No server-level token needed.
# GITHUB_TOKEN=not_used_in_multi_user_mode

# ── Groq LLM (optional — AI explanations) ───────
# Free at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── MongoDB Atlas (optional — profile caching) ───
MONGODB_URI=

# ── Redis (optional — caching) ───────────────────
REDIS_URL=
REDIS_PASSWORD=
