# ================================================
# CodeNova MCP Server — Environment Variables
# ================================================
# Copy this file:
#   Windows:    copy .env.example .env
#   Mac/Linux:  cp .env.example .env
#
# Then fill in the values below and save .env.
# Never commit .env to git — it's already in .gitignore.
# ================================================


# ── GitHub Personal Access Token (REQUIRED) ─────────────────────────
#
# Create one at: https://github.com/settings/tokens
# Click "Generate new token (classic)"
# Required scopes: read:user   public_repo
#
GITHUB_TOKEN=ghp_your_token_here


# ── Groq LLM API Key (optional — enables AI explanations) ───────────
#
# Free tier available at: https://console.groq.com
# Without this, explain_code_file() returns source code only.
#
GROQ_API_KEY=


# ── MongoDB URI (optional — enables profile caching across restarts) ─
#
# Local:   mongodb://localhost:27017/codenova
# Atlas:   mongodb+srv://user:pass@cluster.mongodb.net/codenova
# Without this, profiles are fetched fresh from GitHub each time.
#
MONGODB_URI=


# ── Redis URL (optional — enables request-level caching) ────────────
#
# Local:  redis://localhost:6379
# Cloud:  redis://default:password@host:port
# Without this, GitHub API is called on every request.
#
REDIS_URL=
REDIS_PASSWORD=
