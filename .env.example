# ================================================
# CodeNova MCP Server - Environment Variables
# ================================================
# Copy: copy .env.example .env   (Windows)
#       cp .env.example .env     (Linux/Mac)
# ================================================

# ── WHO THIS SERVER BELONGS TO (REQUIRED) ───────
# Lock the server to your GitHub account.
# No tool accepts a username input — always uses this.
GITHUB_USERNAME=your_github_username

# ── Tool Access Secret (REQUIRED) ───────────────
# Every tool call must pass this as the `secret` argument.
# Generate one: python -c "import secrets; print(secrets.token_hex(24))"
MCP_SECRET=your_secret_here

# ── GitHub Personal Access Token (REQUIRED) ─────
# https://github.com/settings/tokens → classic token
# Scopes: read:user, public_repo
GITHUB_TOKEN=ghp_your_token_here

# ── Groq LLM (optional — AI explanations) ───────
# Free at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# ── MongoDB Atlas (optional — profile caching) ───
MONGODB_URI=

# ── Redis (optional — caching) ───────────────────
REDIS_URL=
REDIS_PASSWORD=
