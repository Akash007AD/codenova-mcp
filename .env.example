# ================================================
# CodeNova MCP Server - Environment Variables
# ================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env   (Windows CMD)
#   cp .env.example .env     (Mac / Linux)

# ── MongoDB Atlas ───────────────────────────────
# Local Docker  : mongodb://root:password@localhost:27017/codenova?authSource=admin
# Atlas (cloud) : mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/codenova?retryWrites=true&w=majority
MONGODB_URI=mongodb://root:password@localhost:27017/codenova?authSource=admin

# ── Redis ───────────────────────────────────────
# Local Docker  : redis://localhost:6379
# Redis Cloud   : redis://:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── GitHub OAuth App ────────────────────────────
# Create at: https://github.com/settings/developers → New OAuth App
#   Homepage URL  : http://localhost:3000
#   Callback URL  : http://localhost:8000/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/auth/github/callback

# ── GitHub Personal Access Token ────────────────
# Used by background indexing jobs (read:public_repo scope is enough)
# Create at: https://github.com/settings/tokens → Generate new token (classic)
# Required scopes: repo, read:user, user:email
GITHUB_TOKEN=ghp_your_personal_access_token

# ── LLM Providers ───────────────────────────────
# DEFAULT (free): Groq — sign up at https://console.groq.com
# The server uses Groq out of the box; no Anthropic key needed unless
# you switch to Option B in main.py.
GROQ_API_KEY=gsk_your_groq_api_key

# OPTIONAL (paid): Anthropic Claude — https://console.anthropic.com
# Uncomment Option B in main.py to activate this provider.
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── JWT (session tokens) ────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168

# ── Fernet Encryption (GitHub token storage) ────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# ── Frontend / CORS ─────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Server Config ───────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=True
ENVIRONMENT=development
